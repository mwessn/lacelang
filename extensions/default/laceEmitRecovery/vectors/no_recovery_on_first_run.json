{
  "id": "no_recovery_on_first_run",
  "description": "When no previous result exists (first run), no recovery notification fires — there is no transition to detect.",
  "spec_refs": ["lace-extensions.md §12"],
  "type": "extension",
  "requires": ["extensions", "actions"],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/ok\").expect(status: 200)\n",
    "variables": {},
    "extensions": ["laceNotifications", "laceEmitRecovery"],
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": "IGNORED",
      "actions": {}
    },
    "ignore": ["startedAt", "endedAt", "calls"]
  }
}
