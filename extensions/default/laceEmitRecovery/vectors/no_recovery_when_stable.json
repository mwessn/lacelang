{
  "id": "no_recovery_when_stable",
  "description": "When previous outcome was success and current is also success, no recovery notification fires — there is no transition.",
  "spec_refs": ["lace-extensions.md §12"],
  "type": "extension",
  "requires": ["extensions", "actions"],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/ok\").expect(status: 200)\n",
    "variables": {},
    "extensions": ["laceNotifications", "laceEmitRecovery"],
    "prev_results": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": [
        {
          "index": 0,
          "outcome": "success",
          "request": { "url": "http://127.0.0.1:9999/ok", "method": "get", "headers": {} },
          "response": { "status": 200, "headers": {}, "responseTimeMs": 100 },
          "redirects": [],
          "assertions": [
            { "method": "expect", "scope": "status", "op": "eq", "outcome": "passed", "actual": 200, "expected": 200, "options": null }
          ],
          "config": {},
          "warnings": [],
          "error": null
        }
      ],
      "actions": {}
    },
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": "IGNORED",
      "actions": {}
    },
    "ignore": ["startedAt", "endedAt", "calls"]
  }
}
