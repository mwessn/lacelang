{
  "id": "recovery_from_timeout",
  "description": "When previous outcome was timeout and current outcome is success, laceEmitRecovery emits a recovered notification. Timeout is treated the same as failure.",
  "spec_refs": ["lace-extensions.md §12"],
  "type": "extension",
  "requires": ["extensions", "actions"],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/ok\").expect(status: 200)\n",
    "variables": {},
    "extensions": ["laceNotifications", "laceEmitRecovery"],
    "prev_results": {
      "outcome": "timeout",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": [
        {
          "index": 0,
          "outcome": "timeout",
          "request": { "url": "http://127.0.0.1:9999/ok", "method": "get", "headers": {} },
          "response": null,
          "redirects": [],
          "assertions": [],
          "config": {},
          "warnings": [],
          "error": "request timed out after 30000ms"
        }
      ],
      "actions": {}
    },
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": "IGNORED",
      "actions": {
        "notifications": [
          {
            "callIndex": -1,
            "conditionIndex": -1,
            "trigger": "recovered",
            "scope": null,
            "notification": {
              "tag": "text",
              "value": "Service recovered"
            }
          }
        ]
      }
    },
    "ignore": ["startedAt", "endedAt", "calls"]
  }
}
